{
    "version": 2,
    "builds": [
        {
            "src": "src/server.js",
            "use": "@vercel/node"
        },
        {
            "src": "public/**/*",
            "use": "@vercel/static"
        }
    ],
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "src/server.js"
        },
        {
            "src": "/assets/(.*)",
            "dest": "public/assets/$1"
        },
        {
            "src": "/admin/assets/(.*)",
            "dest": "public/admin/assets/$1"
        },
        {
            "src": "/admin/(.*)",
            "dest": "public/admin/$1"
        },
        {
            "src": "/",
            "dest": "public/index.html"
        },
        {
            "src": "/(.*)",
            "dest": "src/server.js"
        }
    ]
}